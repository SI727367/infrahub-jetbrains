<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>app.opsmill.infrahub</id>
    <name>Infrahub</name>
    <vendor>OpsMill</vendor>
    <description><![CDATA[
        <p><b>Infrahub</b> is a JetBrains IntelliJ plugin for managing Infrahub infrastructure automation.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <!-- Phase 1: Settings/Configuration Service -->
    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="app.opsmill.infrahub.settings.InfrahubSettingsState"/>
        <applicationConfigurable instance="app.opsmill.infrahub.settings.InfrahubSettingsConfigurable"
            displayName="Infrahub" id="app.opsmill.infrahub.settings"/>
        <statusBarWidgetFactory id="InfrahubStatusBar"
            implementation="app.opsmill.infrahub.statusbar.InfrahubStatusBarWidgetFactory"/>
        <gotoDeclarationHandler implementation="app.opsmill.infrahub.yaml.InfrahubGotoDeclarationHandler"/>
        <lang.psiStructureViewFactory language="yaml"
            implementationClass="app.opsmill.infrahub.yaml.InfrahubStructureViewFactory"/>
    </extensions>

    <!-- Phase 6: Branch Management Actions -->
    <actions>
        <action id="Infrahub.NewBranch" class="app.opsmill.infrahub.actions.NewBranchAction"
            text="New Branch" description="Create a new Infrahub branch" icon="AllIcons.General.Add">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="Infrahub.DeleteBranch" class="app.opsmill.infrahub.actions.DeleteBranchAction"
            text="Delete Branch" description="Delete an Infrahub branch" icon="AllIcons.Actions.GC">
            <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="Infrahub.NewBranch"/>
        </action>
        <action id="Infrahub.VisualizeSchema" class="app.opsmill.infrahub.actions.VisualizeSchemaAction"
            text="Visualize Schema" description="Visualize Infrahub schema" icon="AllIcons.Actions.ShowViewer" >
            <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="Infrahub.DeleteBranch"/>
        </action>
        <action id="Infrahub.CheckSchemaFile" class="app.opsmill.infrahub.actions.CheckSchemaFileAction"
            text="Check Schema File" description="Validate a schema file with infrahubctl">
            <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="Infrahub.VisualizeSchema"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
        </action>
        <action id="Infrahub.LoadSchemaFile" class="app.opsmill.infrahub.actions.LoadSchemaFileAction"
            text="Load Schema File" description="Load a schema file with infrahubctl">
            <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="Infrahub.CheckSchemaFile"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
        </action>
        <action id="Infrahub.CheckAllSchemaFiles" class="app.opsmill.infrahub.actions.CheckAllSchemaFilesAction"
            text="Check Schema File or Directory" description="Validate a schema file or directory with infrahubctl">
            <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="Infrahub.LoadSchemaFile"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
        <action id="Infrahub.LoadAllSchemaFiles" class="app.opsmill.infrahub.actions.LoadAllSchemaFilesAction"
            text="Load Schema File or Directory" description="Load a schema file or directory with infrahubctl">
            <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="Infrahub.CheckAllSchemaFiles"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
        <action id="Infrahub.RunTransform" class="app.opsmill.infrahub.actions.RunTransformAction"
            text="Run Transform" description="Run an Infrahub transform with infrahubctl">
            <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="Infrahub.LoadAllSchemaFiles"/>
        </action>
        <action id="Infrahub.ShowInfrahubctlGuidance" class="app.opsmill.infrahub.actions.ShowInfrahubctlGuidanceAction"
            text="Show infrahubctl Installation Guidance" description="Show installation help for infrahubctl">
            <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="Infrahub.RunTransform"/>
        </action>
    </actions>
</idea-plugin>
